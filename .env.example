POSTGRES_DB=aws_dashboard
POSTGRES_USER=dashboard
POSTGRES_PASSWORD=dashboard
DATABASE_URL=postgresql+psycopg://dashboard:dashboard@postgres:5432/aws_dashboard

API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
PUBLIC_APP_URL=http://localhost:3000
SEED_DAYS=90

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Authentication is deliberately disabled for the self-contained local demo.
# Set both flags to true only after configuring Cognito as described in
# docs/authentication.md. NEXT_PUBLIC_AUTH_ENABLED is compiled into the web
# image, so rebuild the web image after changing it.
AUTH_ENABLED=false
NEXT_PUBLIC_AUTH_ENABLED=false
AUTH_CLOCK_SKEW_SECONDS=60

# HTTP loopback callbacks may use non-Secure cookies for local Cognito testing.
# Every non-loopback production callback forces Secure cookies regardless of
# this value.
AUTH_COOKIE_SECURE=false

# Cognito Managed Login / OAuth settings. Use one public app client with no
# client secret, authorization-code flow plus PKCE, and openid email profile
# scopes. COGNITO_CLIENT_ID and COGNITO_APP_CLIENT_ID must be the same value.
COGNITO_DOMAIN=
COGNITO_CLIENT_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_REGION=
COGNITO_USER_POOL_ID=
# These are derived from region + user-pool ID when left empty.
COGNITO_ISSUER=
COGNITO_JWKS_URL=
COGNITO_JWKS_CACHE_SECONDS=3600
# The API derives this HTTPS endpoint from COGNITO_DOMAIN when blank.
COGNITO_USERINFO_URL=
COGNITO_SCOPES=openid email profile
COGNITO_REDIRECT_URI=http://localhost:3000/auth/callback
COGNITO_LOGOUT_URI=http://localhost:3000/
COGNITO_REFRESH_TOKEN_MAX_AGE_SECONDS=2592000

# Set these only when applying the tenancy migration to an existing database
# with non-demo connections. The migration deliberately stops without a
# bootstrap owner instead of assigning those connections implicitly. Set an
# explicit issuer or provide COGNITO_REGION plus COGNITO_USER_POOL_ID so the
# owner matches the identity created at first Cognito login.
AUTH_BOOTSTRAP_OWNER_SUB=
AUTH_BOOTSTRAP_OWNER_EMAIL=
AUTH_BOOTSTRAP_OWNER_ISSUER=
AUTH_BOOTSTRAP_WORKSPACE_NAME=

# Optional AWS runtime settings for real org-management or standalone account-role syncs.
# Prefer short-lived credentials or a mounted read-only AWS config directory instead of long-lived keys.
AWS_PROFILE=default
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
AWS_SDK_LOAD_CONFIG=1

# To mount your host AWS config into the API container, set AWS_CONFIG_DIR and use:
# docker compose -f docker-compose.yml -f docker-compose.aws.yml up --build
# Example Windows path: C:/Users/your-user/.aws
# Example macOS/Linux path: /Users/your-user/.aws
AWS_CONFIG_DIR=

# Optional environment-based credentials. Prefer temporary credentials and do not commit real values.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
