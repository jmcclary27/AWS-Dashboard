POSTGRES_DB=aws_dashboard
POSTGRES_USER=dashboard
POSTGRES_PASSWORD=dashboard
DATABASE_URL=postgresql+psycopg://dashboard:dashboard@postgres:5432/aws_dashboard

API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
SEED_DAYS=90

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Optional AWS runtime settings for real org-management or standalone account-role syncs.
# Prefer short-lived credentials or a mounted read-only AWS config directory instead of long-lived keys.
AWS_PROFILE=default
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
AWS_SDK_LOAD_CONFIG=1

# To mount your host AWS config into the API container, set AWS_CONFIG_DIR and use:
# docker compose -f docker-compose.yml -f docker-compose.aws.yml up --build
# Example Windows path: C:/Users/your-user/.aws
# Example macOS/Linux path: /Users/your-user/.aws
AWS_CONFIG_DIR=

# Optional environment-based credentials. Prefer temporary credentials and do not commit real values.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
